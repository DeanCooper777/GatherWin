<Window x:Class="GatherWin.Views.GatherLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Gather.is Login" Width="900" Height="700"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Address bar -->
        <Border Grid.Row="0" Background="#F8F9FA" Padding="8,6"
                BorderBrush="#DEE2E6" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Log in to gather.is, then your session token will be detected automatically."
                           FontSize="11" Foreground="#555" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- WebView2 -->
        <wv2:WebView2 x:Name="WebView" Grid.Row="1"
                      Source="https://gather.is/app"/>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#F8F9FA" Padding="8,6"
                BorderBrush="#DEE2E6" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Grid.Column="0"
                           Text="Waiting for login..." FontSize="11" Foreground="#555"
                           VerticalAlignment="Center"/>
                <Button x:Name="CloseBtn" Grid.Column="1" Content="Close"
                        Padding="16,4" FontSize="11" Click="CloseBtn_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
